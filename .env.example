# Anthropic API key (required for booklet generation)
ANTHROPIC_API_KEY=sk-ant-...

# Google Drive folder ID (the top-level "GCSE Combined Science — Self-Study Booklets" folder)
# Find this in the URL when you open the folder: drive.google.com/drive/folders/THIS_PART
GDRIVE_ROOT_FOLDER_ID=

# Path to Google OAuth client credentials JSON file
# Download from: console.cloud.google.com > APIs & Services > Credentials > OAuth 2.0 Client IDs
GOOGLE_CLIENT_SECRETS_FILE=client_secret.json

# OpenAI API key (optional — for DALL-E 3 diagram generation)
# Get a key from platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
